# Server
HOST=0.0.0.0
PORT=8000
PRODUCTION=false
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# AI Provider (ollama or openai)
AI_PROVIDER=ollama
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2:latest
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# Database (defaults to backend/data/avios.db if empty)
DATABASE_URL=

# Daily message limit per user (resets at midnight UTC)
DAILY_MESSAGE_LIMIT=100

# JWT
JWT_SECRET=avios-jwt-secret-change-in-production
JWT_EXPIRE_MINUTES=1440

# SMTP (optional — for password reset and email verification)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@email.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM_EMAIL=noreply@avios.ai
# APP_BASE_URL=http://localhost:5173
